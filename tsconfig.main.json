{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noUncheckedIndexedAccess": false
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "src/main/**/*.test.ts"
  ]
}
