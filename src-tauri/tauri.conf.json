{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tezbar",
  "version": "0.0.3",
  "identifier": "com.tezbar.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5174",
    "additionalWatchFolders": ["../dist-backend"],
    "beforeDevCommand": "pnpm exec tsx scripts/build-backend.ts && pnpm exec vite",
    "beforeBuildCommand": "pnpm exec tsx scripts/build-backend.ts && pnpm exec vite build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Tezbar",
        "width": 760,
        "height": 640,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist-backend/main.js": "dist-backend/main.js",
      "../native/axhelper/axhelper": "native/axhelper/axhelper",
      "../native/screenocr/screenocr-helper": "native/screenocr/screenocr-helper",
      "../node_modules/@esbuild/darwin-arm64/bin/esbuild": "bin/esbuild",
      "../resources/trayIconTemplate.png": "trayIconTemplate.png",
      "../resources/trayIconTemplate@2x.png": "trayIconTemplate@2x.png"
    }
  }
}
