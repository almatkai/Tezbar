{
  "name": "raymes",
  "version": "0.0.1",
  "private": true,
  "description": "Raymes",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "bash -lc 'unset ELECTRON_RUN_AS_NODE; exec electron-vite dev'",
    "postinstall": "node scripts/fix-node-pty-permissions.mjs",
    "build": "electron-vite build",
    "preview": "bash -lc 'unset ELECTRON_RUN_AS_NODE; exec electron-vite preview'",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "test": "vitest run",
    "build:native:input": "./native/input/build-universal.sh",
    "build:native:axhelper": "./native/axhelper/build.sh",
    "build:native": "pnpm build:native:input && pnpm build:native:axhelper",
    "dist": "pnpm build && pnpm build:native && electron-builder"
  },
  "build": {
    "appId": "com.raymes.app",
    "productName": "Raymes",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "native/input/index.node",
      "native/axhelper/axhelper",
      "node_modules/esbuild/**/*",
      "node_modules/@esbuild/**/*",
      "package.json",
      "!node_modules/better-sqlite3/deps",
      "!node_modules/better-sqlite3/deps/**/*",
      "!node_modules/better-sqlite3/src",
      "!node_modules/better-sqlite3/src/**/*",
      "!node_modules/better-sqlite3/build/Release/obj",
      "!node_modules/better-sqlite3/build/Release/obj/**/*",
      "!node_modules/better-sqlite3/binding.gyp",
      "!node_modules/node-pty/deps",
      "!node_modules/node-pty/deps/**/*",
      "!node_modules/node-pty/scripts",
      "!node_modules/node-pty/scripts/**/*",
      "!node_modules/node-pty/src",
      "!node_modules/node-pty/src/**/*",
      "!node_modules/node-pty/prebuilds/win32-arm64",
      "!node_modules/node-pty/prebuilds/win32-arm64/**/*",
      "!node_modules/node-pty/prebuilds/win32-x64",
      "!node_modules/node-pty/prebuilds/win32-x64/**/*",
      "!node_modules/node-pty/lib/**/*.test.js",
      "!node_modules/node-pty/lib/**/*.test.js.map",
      "!node_modules/node-pty/lib/**/*.js.map"
    ],
    "asarUnpack": [
      "native/input/index.node",
      "native/axhelper/axhelper",
      "node_modules/node-pty/build/Release/*.node",
      "node_modules/better-sqlite3/build/Release/*.node"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "dompurify": "^3.4.0",
    "esbuild": "^0.28.0",
    "fuse.js": "^7.3.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "marked-highlight": "^2.2.4",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "0.28.0",
    "@esbuild/darwin-x64": "0.28.0"
  },
  "devDependencies": {
    "@raycast/api": "^1.104.13",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.6",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "electron": "^33.4.8",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.3",
    "vitest": "^3.1.2"
  },
  "packageManager": "pnpm@11.1.3"
}
